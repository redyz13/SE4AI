{
  "metadata": {
    "project": "SE4AI",
    "file": "final_replacement_taxonomy.json",
    "purpose": "Replacement-aware bias taxonomy for controlled counterfactual prompt generation.",
    "sources": [
      "CrowS-Pairs lexicon",
      "BBQ taxonomy/lexicon",
      "HolisticBias descriptors/lexicon"
    ],
    "design_principle": "Terms are grouped by bias axis and replacement group. Terms should only be rotated within the same replacement group and compatible slot type.",
    "note": "This file complements the task taxonomy. It prevents invalid substitutions such as replacing a person name with a pronoun, or a nationality adjective with a migration status."
  },
